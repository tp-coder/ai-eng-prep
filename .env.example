APP_ENV=local
APP_NAME=ai-engineering-prep
LOG_LEVEL=INFO

# LLM Settings
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# RAG Settings
DOCS_PATH=data/docs
INDEX_PATH=data/index/documents.json
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=4
RETRIEVAL_MIN_SCORE=0.25